{
  "agents": {
    "defaults": {
      "workspace": "/home/agent/nanobot",
      "model": "claude-sonnet-4-20250514",
      "max_iterations": 10,
      "max_tokens": 8192,
      "temperature": 0.1
    }
  },
  "providers": {
    "anthropic": {
      "api_key": "proxy-managed"
    }
  },
  "tools": {
    "exec": {
      "enabled": true,
      "timeout_seconds": 30,
      "restrictToWorkspace": true
    }
  }
}
